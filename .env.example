# Embedding 配置（OpenAI 兼容，默认用 Ollama）
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_API_KEY=ollama

# LLM 配置（RAG 生成，OpenAI 兼容）
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5
LLM_API_KEY=ollama
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Reranker 配置（重排序）
RERANKER_ENABLED=false
RERANKER_MODEL=bge-reranker-v2-m3

# 向量存储配置
VECTOR_STORE_TYPE=faiss       # faiss | milvus
# MILVUS_URI=                 # 空=本地 LanceDB, http://host:19530=远程

# 文档处理
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE=52428800        # 50MB

# 搜索
MAX_SEARCH_RESULTS=20
LOG_LEVEL=INFO

# 模型组配置（主备切换，JSON 格式）
# MODEL_GROUPS={"embedding":[{"base_url":"http://localhost:11434/v1","model":"bge-m3","api_key":"ollama"}],"llm":[{"base_url":"http://localhost:11434/v1","model":"qwen2.5","api_key":"ollama"}]}
